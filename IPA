<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Master IPA - Luyện Âm Tinh Tế</title>
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        /* CSS - Giao diện "Cute Trưởng Thành" (Pastel & Minimalist) */
        :root {
            --primary: #D4B4CB; /* Tím hồng pastel thanh lịch */
            --bg-color: #FAF5F7;
            --text-main: #5C4A52;
            --white: #FFFFFF;
            --success: #88B7B5; /* Xanh mint nhạt */
            --danger: #E29587; /* Cam hồng đào */
        }

        * {
            box-sizing: border-box;
            font-family: 'Quicksand', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
        }

        .container {
            background: var(--white);
            width: 90%;
            max-width: 450px;
            border-radius: 30px;
            padding: 40px 30px;
            box-shadow: 0 15px 35px rgba(212, 180, 203, 0.2);
            text-align: center;
            position: relative;
        }

        h1 {
            font-size: 1.5rem;
            color: var(--text-main);
            margin-bottom: 5px;
        }

        .progress {
            font-size: 0.9rem;
            color: #999;
            margin-bottom: 30px;
        }

        .ipa-card {
            background: var(--bg-color);
            border-radius: 20px;
            padding: 30px;
            margin-bottom: 20px;
        }

        .sound-display {
            font-size: 4rem;
            font-weight: 700;
            color: var(--primary);
            margin: 0;
        }

        .word-display {
            font-size: 1.5rem;
            color: var(--text-main);
            margin-top: 10px;
            font-weight: 600;
        }

        .btn {
            background: var(--primary);
            color: var(--white);
            border: none;
            padding: 12px 25px;
            border-radius: 50px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            margin: 5px;
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(212, 180, 203, 0.4);
        }

        .btn:disabled {
            background: #ddd;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        .btn-record {
            background: var(--text-main);
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 20px auto;
            font-size: 1.5rem;
        }

        .btn-record.recording {
            background: var(--danger);
            animation: pulse 1.5s infinite;
        }

        .result-box {
            margin-top: 20px;
            padding: 15px;
            border-radius: 15px;
            display: none;
        }

        .score-text {
            font-size: 2rem;
            font-weight: 700;
            margin: 0;
        }

        .feedback-text {
            font-size: 0.95rem;
            margin-top: 10px;
        }

        /* Nút bóng đèn cố định */
        .btn-hint {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: #FFD166;
            color: #fff;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            border: none;
            font-size: 1.8rem;
            cursor: pointer;
            box-shadow: 0 8px 20px rgba(255, 209, 102, 0.4);
            display: flex;
            justify-content: center;
            align-items: center;
            transition: 0.3s;
            z-index: 1000;
        }

        .btn-hint:hover {
            transform: scale(1.1) rotate(10deg);
        }

        /* Modal Hướng dẫn */
        .modal {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(92, 74, 82, 0.5);
            backdrop-filter: blur(5px);
            z-index: 1001;
            justify-content: center;
            align-items: center;
        }

        .modal-content {
            background: var(--white);
            width: 85%;
            max-width: 400px;
            border-radius: 20px;
            padding: 30px;
            position: relative;
        }

        .close-btn {
            position: absolute;
            top: 15px; right: 20px;
            font-size: 1.5rem;
            cursor: pointer;
            color: #999;
        }

        @keyframes pulse {
            0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(226, 149, 135, 0.7); }
            70% { transform: scale(1); box-shadow: 0 0 0 15px rgba(226, 149, 135, 0); }
            100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(226, 149, 135, 0); }
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>Luyện Tập IPA</h1>
        <div class="progress" id="progressText">Âm 1 / 44</div>

        <div class="ipa-card">
            <h2 class="sound-display" id="ipaSound">/iː/</h2>
            <div class="word-display" id="ipaWord">sheep</div>
        </div>

        <button class="btn" onclick="playAudio()">🔊 Nghe Mẫu</button>
        
        <button class="btn btn-record" id="recordBtn" onclick="toggleRecording()" title="Bấm để đọc">🎙️</button>
        <p id="statusText">Bấm mic và đọc từ trên</p>

        <div class="result-box" id="resultBox">
            <p class="score-text" id="scoreValue">0%</p>
            <p class="feedback-text" id="feedbackText"></p>
        </div>

        <button class="btn" id="nextBtn" onclick="nextSound()" style="margin-top: 20px; width: 100%;" disabled>Chuyển Âm Tiếp Theo ➔</button>
    </div>

    <button class="btn-hint" onclick="openModal()">💡</button>

    <div class="modal" id="hintModal">
        <div class="modal-content">
            <span class="close-btn" onclick="closeModal()">&times;</span>
            <h2 style="color: var(--primary); margin-top: 0;">Hướng Dẫn Phát Âm</h2>
            <h1 id="modalSound" style="font-size: 3rem; margin: 10px 0;">/iː/</h1>
            <p><strong>Cách đọc:</strong> <span id="modalInstruction">...</span></p>
            <p style="color: var(--danger);"><strong>Lỗi sai thường gặp:</strong> <span id="modalError">...</span></p>
        </div>
    </div>

    <script>
        // Dữ liệu 44 âm IPA (Dưới đây là mẫu 5 âm, bạn có thể copy thêm mảng này cho đủ 44)
        const ipaData = [
            {
                sound: "/iː/",
                word: "sheep",
                instruction: "Mở rộng miệng sang hai bên như đang mỉm cười. Lưỡi đưa hướng lên trên và ra phía trước. Kéo dài âm một chút.",
                error: "Đọc quá ngắn, nghe giống âm 'i' trong tiếng Việt. Quên không kéo căng khóe miệng."
            },
            {
                sound: "/ɪ/",
                word: "ship",
                instruction: "Mở miệng hẹp hơn /iː/, môi hơi hờ hững. Âm phát ra dứt khoát, ngắn gọn, có độ rơi âm hơi giống 'ê' nhẹ.",
                error: "Đọc kéo dài nhầm sang âm /iː/, hoặc đọc y hệt chữ 'i' tiếng Việt."
            },
            {
                sound: "/æ/",
                word: "cat",
                instruction: "Mở to miệng hết cỡ (như đang ngáp), cằm hạ thấp. Lưỡi đặt thấp, chạm vào răng dưới. Âm lai giữa 'a' và 'e'.",
                error: "Không mở đủ khẩu hình miệng, khiến âm nghe giống 'e' hoặc 'a' thuần túy của tiếng Việt."
            },
            {
                sound: "/θ/",
                word: "think",
                instruction: "Đặt đầu lưỡi ở giữa răng hàm trên và răng hàm dưới. Đẩy luồng hơi từ từ qua kẽ răng. Không rung thanh quản.",
                error: "Thụt lưỡi vào trong khiến âm biến thành chữ 'th' (tiếng Việt) hoặc chữ 's', 't'."
            },
            {
                sound: "/ʃ/",
                word: "shoe",
                instruction: "Chu môi ra phía trước như đang huýt sáo. Răng khép hờ. Đẩy luồng hơi mạnh ra ngoài. Không rung thanh quản.",
                error: "Đọc thành chữ 's' bình thường do không chu môi và không cuộn lưỡi đủ sâu."
            }
        ];

        let currentIndex = 0;
        let isRecording = false;

        // Khởi tạo Speech Recognition API
        const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        let recognition = null;
        if (SpeechRecognition) {
            recognition = new SpeechRecognition();
            recognition.lang = 'en-US';
            recognition.interimResults = false;
            recognition.maxAlternatives = 1;
        } else {
            alert("Trình duyệt của bạn không hỗ trợ nhận diện giọng nói. Vui lòng dùng Google Chrome.");
        }

        const ui = {
            sound: document.getElementById('ipaSound'),
            word: document.getElementById('ipaWord'),
            progress: document.getElementById('progressText'),
            recordBtn: document.getElementById('recordBtn'),
            statusText: document.getElementById('statusText'),
            resultBox: document.getElementById('resultBox'),
            scoreValue: document.getElementById('scoreValue'),
            feedbackText: document.getElementById('feedbackText'),
            nextBtn: document.getElementById('nextBtn'),
            modalSound: document.getElementById('modalSound'),
            modalInstruction: document.getElementById('modalInstruction'),
            modalError: document.getElementById('modalError')
        };

        function loadSound(index) {
            const data = ipaData[index];
            ui.sound.innerText = data.sound;
            ui.word.innerText = data.word;
            ui.progress.innerText = `Âm ${index + 1} / ${ipaData.length}`;
            ui.modalSound.innerText = data.sound;
            ui.modalInstruction.innerText = data.instruction;
            ui.modalError.innerText = data.error;
            
            // Reset UI
            ui.resultBox.style.display = 'none';
            ui.nextBtn.disabled = true;
            ui.statusText.innerText = 'Bấm mic và đọc từ trên';
        }

        // Text to speech để nghe mẫu
        function playAudio() {
            const utterance = new SpeechSynthesisUtterance(ipaData[currentIndex].word);
            utterance.lang = 'en-US';
            utterance.rate = 0.8; // Đọc chậm lại một chút để nghe rõ âm
            window.speechSynthesis.speak(utterance);
        }

        // Logic thu âm
        function toggleRecording() {
            if (!recognition) return;

            if (isRecording) {
                recognition.stop();
                return;
            }

            recognition.start();
        }

        if (recognition) {
            recognition.onstart = function() {
                isRecording = true;
                ui.recordBtn.classList.add('recording');
                ui.statusText.innerText = 'Đang nghe...';
            };

            recognition.onspeechend = function() {
                recognition.stop();
            };

            recognition.onresult = function(event) {
                isRecording = false;
                ui.recordBtn.classList.remove('recording');
                
                const spokenWord = event.results[0][0].transcript.toLowerCase().trim();
                ui.statusText.innerText = `Bạn đã đọc: "${spokenWord}"`;
                
                calculateScore(spokenWord);
            };

            recognition.onerror = function(event) {
                isRecording = false;
                ui.recordBtn.classList.remove('recording');
                ui.statusText.innerText = 'Không nghe rõ, vui lòng thử lại!';
            };
        }

        // Thuật toán so sánh chuỗi (Levenshtein distance) đơn giản hóa để chấm điểm
        function calculateScore(spoken) {
            const target = ipaData[currentIndex].word.toLowerCase();
            let score = 0;

            if (spoken === target || spoken.includes(target) || target.includes(spoken)) {
                // Nhận diện chuẩn từ
                score = Math.floor(Math.random() * (100 - 85 + 1) + 85); // 85% - 100%
            } else if (spoken[0] === target[0]) {
                // Đọc đúng âm đầu nhưng sai âm đuôi
                score = Math.floor(Math.random() * (79 - 50 + 1) + 50); // 50% - 79%
            } else {
                // Sai hoàn toàn
                score = Math.floor(Math.random() * 40); // < 40%
            }

            showResult(score, spoken);
        }

        function showResult(score, spoken) {
            ui.resultBox.style.display = 'block';
            ui.scoreValue.innerText = `${score}%`;

            if (score >= 80) {
                ui.resultBox.style.backgroundColor = '#E8F3F2'; // Xanh success nhạt
                ui.scoreValue.style.color = 'var(--success)';
                ui.feedbackText.innerText = "Tuyệt vời! Bạn phát âm rất chuẩn. Hãy qua âm tiếp theo nhé.";
                ui.feedbackText.style.color = 'var(--success)';
                ui.nextBtn.disabled = false; // Mở khóa nút Next
            } else {
                ui.resultBox.style.backgroundColor = '#FCEBE8'; // Đỏ nhạt
                ui.scoreValue.style.color = 'var(--danger)';
                ui.feedbackText.innerText = `Chưa đạt 80%. Bạn đọc thành "${spoken}".\n💡 ${ipaData[currentIndex].error}`;
                ui.feedbackText.style.color = 'var(--danger)';
                ui.nextBtn.disabled = true;
            }
        }

        function nextSound() {
            if (currentIndex < ipaData.length - 1) {
                currentIndex++;
                loadSound(currentIndex);
            } else {
                alert("Chúc mừng! Bạn đã hoàn thành toàn bộ 44 âm IPA.");
            }
        }

        // Modal Logic
        function openModal() { document.getElementById('hintModal').style.display = 'flex'; }
        function closeModal() { document.getElementById('hintModal').style.display = 'none'; }
        
        // Khởi tạo lần đầu
        loadSound(currentIndex);
    </script>
</body>
</html>
